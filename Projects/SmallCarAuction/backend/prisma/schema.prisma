generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  BUYER
}

enum AuctionState {
  DRAFT
  ACTIVE
  ENDED
  CANCELLED
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  role          UserRole
  bids          Bid[]
  wonAuctions   Auction[]      @relation("AuctionWinner")
  otpChallenges OtpChallenge[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model OtpChallenge {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([userId, expiresAt])
}

model Vehicle {
  id        String   @id @default(uuid())
  brand     String
  model     String
  vin       String   @unique
  auction   Auction?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Auction {
  id            String       @id @default(uuid())
  vehicleId     String       @unique
  vehicle       Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  startingPrice Decimal      @db.Decimal(12, 2)
  currentPrice  Decimal      @db.Decimal(12, 2)
  endTime       DateTime
  state         AuctionState @default(DRAFT)
  bids          Bid[]        @relation("AuctionBids")
  winnerBuyerId String?
  winnerBuyer   User?        @relation("AuctionWinner", fields: [winnerBuyerId], references: [id])
  winningBidId  String?      @unique
  winningBid    Bid?         @relation("WinningBid", fields: [winningBidId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([state, endTime])
  @@index([winnerBuyerId])
}

model Bid {
  id        String   @id @default(uuid())
  auctionId String
  auction   Auction  @relation("AuctionBids", fields: [auctionId], references: [id], onDelete: Cascade)
  buyerId   String
  buyer     User     @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  wonAuction Auction? @relation("WinningBid")
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  @@index([auctionId, amount, createdAt])
  @@index([buyerId])
}
